{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "YOUR_FIREBASE_PROJECT_ID",
          "appId": "YOUR_ANDROID_APP_ID",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "YOUR_FIREBASE_PROJECT_ID",
          "configurations": {
            "android": "YOUR_ANDROID_APP_ID",
            "ios": "YOUR_IOS_APP_ID",
            "web": "YOUR_WEB_APP_ID",
            "windows": "YOUR_WINDOWS_APP_ID"
          }
        },
        "lib/firebase_options_goshopping.dart": {
          "projectId": "YOUR_LEGACY_FIREBASE_PROJECT_ID",
          "configurations": {
            "android": "YOUR_LEGACY_ANDROID_APP_ID",
            "ios": "YOUR_LEGACY_IOS_APP_ID",
            "web": "YOUR_LEGACY_WEB_APP_ID",
            "windows": "YOUR_LEGACY_WINDOWS_APP_ID"
          }
        }
      }
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.4"
  }
}
